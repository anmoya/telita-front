{
  "name": "telita-front",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <11"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "TSX_TSCONFIG_PATH=tsconfig.test.json node --loader ../telita-back/node_modules/tsx/dist/loader.mjs --test $(find src \\( -name '*.test.ts' -o -name '*.test.tsx' \\))",
    "verify": "npm run build && npm run typecheck && npm test"
  },
  "dependencies": {
    "driver.js": "^1.4.0",
    "next": "15.5.9",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/react": "^19.1.17",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "eslint": "^9.21.0",
    "typescript": "^5.7.3"
  }
}
